{
  "name": "crisplogs",
  "version": "0.2.2",
  "description": "Beautiful, colored, and boxed logging for Node.js.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --fix src/ tests/",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "logging",
    "logger",
    "color",
    "box",
    "formatter",
    "terminal",
    "cli",
    "console"
  ],
  "license": "MIT",
  "author": "Dev Bachani",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dev22603/crisplogs-js.git"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^20.19.39",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
