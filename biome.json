{
	"$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "warn",
				"noControlCharactersInRegex": "off"
			},
			"style": {
				"noNonNullAssertion": "off"
			}
		}
	},
	"files": {
		"includes": ["src/**", "tests/**"]
	}
}
